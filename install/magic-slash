#!/bin/bash
# Magic Slash CLI
# Launch the Magic Slash Desktop app

# Config file path
CONFIG_FILE="$HOME/.config/magic-slash/config.json"

# Read version from config file
if [ -f "$CONFIG_FILE" ]; then
  VERSION=$(jq -r '.version // "unknown"' "$CONFIG_FILE" 2>/dev/null)
else
  VERSION="unknown"
fi

# Check for --help or -h flag
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  echo ""
  echo "Magic Slash v$VERSION"
  echo ""
  echo "Usage:"
  echo "  magic-slash          Open the Magic Slash Desktop app"
  echo "  magic-slash --help   Show this help message"
  echo ""
  exit 0
fi

# Launch the desktop app
if [ -d "/Applications/Magic Slash.app" ]; then
  open -a "Magic Slash"
else
  echo "Error: Magic Slash Desktop app not found in /Applications."
  echo ""
  echo "Please reinstall:"
  echo "  curl -fsSL https://magic-slash.io/install.sh | bash"
  exit 1
fi
