{
  "name": "magic-slash",
  "version": "0.17.5",
  "description": "3 skills for Claude Code that automate the entire development cycle with Jira Tickets and GitHub repositories.",
  "keywords": [
    "claude",
    "claude-code",
    "slash-commands",
    "jira",
    "github",
    "automation",
    "developer-tools",
    "productivity"
  ],
  "homepage": "https://github.com/xrequillart/magic-slash#readme",
  "bugs": {
    "url": "https://github.com/xrequillart/magic-slash/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xrequillart/magic-slash.git"
  },
  "license": "MIT",
  "author": "xrequillart",
  "scripts": {
    "lint": "npm run lint:yaml && npm run lint:js",
    "lint:js": "eslint web-ui/ desktop/src/",
    "lint:yaml": "yamllint -c .yamllint.yml .",
    "web": "node web-ui/server.js",
    "web:install": "cd web-ui && npm install",
    "desktop": "cd desktop && npm run dev",
    "desktop:install": "cd desktop && npm install",
    "desktop:build": "cd desktop && npm run build",
    "desktop:package": "cd desktop && npm run package:mac",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
